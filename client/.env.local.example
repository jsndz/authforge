# Go auth backend base URL.
# The Next.js BFF proxy forwards /api/auth/* requests to this origin.
# In production, point this to your deployed backend.
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8080

# OAuth client id registered in AuthForge OauthClient table.
# Used by the browser to start Google login and complete PKCE exchange.
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_oauth_client_id
